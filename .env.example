# LLM provider configuration
# Set LLM_PROVIDER to one of: minimax | anthropic | openai_compat
# Code falls back automatically across any other providers that have keys.
LLM_PROVIDER=minimax

# MiniMax (OpenAI-compat endpoint)
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-M2.7

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Generic OpenAI-compatible (DeepSeek, Moonshot, Qwen-DashScope, OpenAI,
# OpenRouter, Together, Groq, etc.). Examples:
#   DeepSeek:  base=https://api.deepseek.com/v1            model=deepseek-chat
#   Moonshot:  base=https://api.moonshot.cn/v1             model=moonshot-v1-8k
#   Qwen:      base=https://dashscope.aliyuncs.com/compatible-mode/v1  model=qwen-plus
#   OpenRouter:base=https://openrouter.ai/api/v1           model=anthropic/claude-sonnet-4
#   OpenAI:    base=https://api.openai.com/v1              model=gpt-4o-mini
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# App config
TEAM_ROOT=./team
AGENTS_DIR=./team/agents
TASKS_DIR=./team/tasks
TIMELINE_FILE=./team/timeline.jsonl
CONTEXT_DIR=./team/context

# LLM call timeouts (milliseconds)
ASK_AGENT_TIMEOUT_MS=12000
PMA_SYNTHESIS_TIMEOUT_MS=20000
BOOTSTRAP_PHASE_TIMEOUT_MS=60000
